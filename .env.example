# ============================================================
# EduGen — Szablon konfiguracji
# Skopiuj ten plik jako .env w głównym katalogu projektu
# i uzupełnij wartości przed uruchomieniem aplikacji.
# ============================================================

# ------------------------------------------------------------
# WYMAGANE — JWT (Backend FastAPI)
# ------------------------------------------------------------

# Klucz JWT — WAŻNE: ustaw stały, tajny klucz!
# Jeśli nie ustawisz, klucz jest losowany przy każdym starcie
# → po restarcie kontenera wszyscy użytkownicy zostaną wylogowani
# Wygeneruj: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=zmien_na_losowy_klucz_minimum_32_znaki

# Algorytm podpisu JWT (domyślnie HS256, nie zmieniaj bez potrzeby)
JWT_ALGORITHM=HS256

# Czas życia tokenu JWT w minutach (domyślnie 30)
JWT_EXPIRATION_MINUTES=30

# ------------------------------------------------------------
# WYMAGANE — PostgreSQL (Docker Compose + Backend)
# ------------------------------------------------------------

# Port PostgreSQL (domyślnie 5432)
DB_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edugen_db
POSTGRES_USER=edugen_user
POSTGRES_PASSWORD=edugen_password123!

# ------------------------------------------------------------
# OPCJONALNE — Backend (wartości domyślne w nawiasach)
# ------------------------------------------------------------

# Katalog na dane aplikacji (domyślnie ./data)
DATA_DIR=./data

# Maksymalny rozmiar wgrywanych plików w MB (domyślnie 10)
MAX_FILE_SIZE_MB=10

# Lista dozwolonych origin dla CORS (jako JSON array)
CORS_ORIGINS=["http://localhost:3000"]


# ------------------------------------------------------------
# OPCJONALNE — Frontend (Next.js)
# ------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:8000
APP_NAME=EduGen
APP_VERSION=1.0.1
APP_RELEASE_DATE=2026-03-11