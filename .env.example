# ============================================================
# EduGen — Environment Configuration Example
# Skopiuj ten plik do .env i uzupełnij wartości
# ============================================================


# ------------------------------------------------------------
# WYMAGANE — Docker Compose (root .env)
# ------------------------------------------------------------

# Hasło do bazy PostgreSQL — używane przez docker-compose.yml
POSTGRES_PASSWORD=zmien_na_bezpieczne_haslo


# ------------------------------------------------------------
# WYMAGANE — Backend FastAPI (backend/.env)
# Wklej te zmienne również do backend/.env
# ------------------------------------------------------------

# URL połączenia z PostgreSQL
# W Dockerze DATABASE_URL jest nadpisywany przez docker-compose.yml
# Przydatne do lokalnego uruchomienia backendu poza Dockerem
DATABASE_URL=postgresql+psycopg://edugen_user:zmien_na_bezpieczne_haslo@localhost:5432/edugen

# Klucz JWT — WAŻNE: ustaw stały klucz!
# Jeśli nie ustawisz, klucz jest losowany przy każdym starcie
# → po restarcie kontenera wszyscy użytkownicy zostaną wylogowani
# Generuj: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=wygeneruj_losowy_string_minimum_32_znaki

# Algorytm podpisu JWT (domyślnie HS256, nie zmieniaj bez potrzeby)
JWT_ALGORITHM=HS256

# Czas życia tokenu JWT w minutach (domyślnie 30)
JWT_EXPIRATION_MINUTES=30


# ------------------------------------------------------------
# OPCJONALNE — Backend (wartości domyślne w nawiasach)
# ------------------------------------------------------------

# Katalog na dane aplikacji (domyślnie ./data)
DATA_DIR=./data

# Maksymalny rozmiar wgrywanych plików w MB (domyślnie 10)
MAX_FILE_SIZE_MB=10

# Lista dozwolonych origin dla CORS (jako JSON array)
CORS_ORIGINS=["http://localhost:3000"]