#!/usr/bin/env bash
# EduGen hard reset launcher — otwiera Terminal i uruchamia reset_images_volumes.sh

PROJECT_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

osascript << EOF
tell application "Terminal"
    activate
    do script "cd '$PROJECT_DIR' && bash reset_images_volumes.sh; echo; read -r -p 'Press Enter to close...' dummy"
end tell
EOF
