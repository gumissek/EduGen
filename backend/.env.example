# EduGen Local - Environment Configuration
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=sqlite:///./data/edugen.db

# Default password (bcrypt hash of 'admin')
# Generate new hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
DEFAULT_PASSWORD_HASH=$2b$12$LJ3m4ys3Lk0TSwMCfNBMauZ1vuRpiOj0qmKPp5Gx5g5VZsCxS1SW2

# Data directory
DATA_DIR=./data

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=15

# Max upload file size in MB
MAX_FILE_SIZE_MB=10

# CORS allowed origins
CORS_ORIGINS=["http://localhost:3000"]
