# EduGen Local - Environment Configuration
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=sqlite:///./data/edugen.db

# Default password (bcrypt hash of 'Start1234!')
# Generate new hash: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
DEFAULT_PASSWORD_HASH=$2b$12$6F/0bbS5jodCCxt.GkxhFeU28l6Ox6cdqz8FCCVHE95jbTn1PGKJy

# Data directory
DATA_DIR=./data

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=15

# Max upload file size in MB
MAX_FILE_SIZE_MB=10

# CORS allowed origins
CORS_ORIGINS=["http://localhost:3000"]
